<section class="page-section" id="about">
  <div class="about-inner">
    <div class="about-eyebrow reveal">Who We Are</div>
    <h2 class="about-heading reveal">Scotland's<br>YouTube Studio.</h2>
    <div class="about-body">
      <div class="about-text-block">
        <p class="about-text reveal">
          <strong>Braxton Studios</strong> is a specialist YouTube production company based in Scotland. We work with creators, brands, and businesses who are serious about building audiences that crave new creative voices, pairing the right production with a tailored, data-driven strategy.
        </p>
        <p class="about-text reveal reveal-delay-1" style="margin-top:24px">
          From strategy to screen, we handle everything so that your channel works as hard as you do.
        </p>
        <p class="about-text reveal reveal-delay-1" style="margin-top:24px">
          We also want to lead by example and showcase our original productions in action.
        </p>
      </div>
      <div class="about-stats reveal reveal-delay-1">
        <div class="stat">
          <div class="stat-num">2M+</div>
          <div class="stat-label">Organic YouTube Views</div>
        </div>
        <div class="stat">
          <div class="stat-num">100%</div>
          <div class="stat-label">End-to-End</div>
        </div>
        <div class="stat">
          <div class="stat-num">250+</div>
          <div class="stat-label">Videos Created</div>
        </div>
        <div class="stat">
          <div class="stat-num">500+</div>
          <div class="stat-label">Leads Generated</div>
        </div>
      </div>
      <div class="about-right reveal reveal-delay-2">
        <div class="about-contact">
          <span class="about-contact-label">Work With Us</span>
          <a href="mailto:<%= contactEmail %>" class="about-contact-link"><%= contactEmail %></a>
          <a href="#" class="about-media-kit" target="_blank">Download Media Kit</a>
        </div>
        <form id="contactForm" class="contact-form">
          <input type="text" name="name" placeholder="Your Name" required>
          <input type="email" name="email" placeholder="Your Email" required>
          <textarea name="message" placeholder="Tell us about your project..." required></textarea>
          <button type="submit">Send Message</button>
          <div id="formMessage"></div>
        </form>
      </div>
    </div>
  </div>
</section>
