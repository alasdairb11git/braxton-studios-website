<section class="signup-section">
  <div class="signup-inner">
    <h3 class="signup-heading">Stay in the loop</h3>
    <p class="signup-text">Get updates on new products, productions, and resources.</p>
    <form class="signup-form" id="signupForm">
      <div class="signup-input-wrap">
        <input type="email" name="email" placeholder="Your email" required class="signup-input">
        <button type="submit" class="signup-btn">Subscribe</button>
      </div>
      <label class="signup-consent">
        <input type="checkbox" name="consent" required>
        <span>I agree to the <a href="/privacy-policy" target="_blank">Privacy Policy</a></span>
      </label>
      <p class="signup-msg" id="signupMsg"></p>
    </form>
  </div>
</section>
