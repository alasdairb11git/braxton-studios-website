<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/cursor') %>
  <%- include('partials/nav') %>

  <section class="listing-hero">
    <div class="listing-hero-content reveal">
      <span class="cs-hero-eyebrow">Our Work</span>
      <h1 class="cs-hero-title">Campaigns</h1>
      <p class="audit-hero-sub">Podcast production, artist campaigns, and brand partnerships.</p>
    </div>
  </section>

  <section class="listing-grid">
    <a href="/campaigns/building-brand-advocacy" class="listing-card reveal">
      <div class="listing-card-img">
        <img src="/images/bba-podcast.jpg" alt="Building Brand Advocacy">
        <div class="listing-card-overlay"></div>
      </div>
      <div class="listing-card-info">
        <h2 class="listing-card-title">Building Brand Advocacy</h2>
        <p class="listing-card-sub">Podcast Production — Archive House Agency</p>
      </div>
    </a>
    <a href="/campaigns/adum" class="listing-card reveal reveal-delay-1">
      <div class="listing-card-img">
        <img src="/images/adum.jpg" alt="Adum">
        <div class="listing-card-overlay"></div>
      </div>
      <div class="listing-card-info">
        <h2 class="listing-card-title">Adum</h2>
        <p class="listing-card-sub">Musician — Artist Campaign</p>
      </div>
    </a>
    <a href="/about/alasdair-braxton" class="listing-card reveal reveal-delay-2">
      <div class="listing-card-img">
        <img src="/images/ab-easdale.jpg" alt="Alasdair Braxton">
        <div class="listing-card-overlay"></div>
      </div>
      <div class="listing-card-info">
        <h2 class="listing-card-title">Alasdair Braxton</h2>
        <p class="listing-card-sub">Founder & Filmmaker — Braxton Studios</p>
      </div>
    </a>
  </section>

  <%- include('partials/signup') %>
  <%- include('partials/footer') %>
  <%- include('partials/scripts') %>
</body>
</html>
