<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/cursor') %>
  <%- include('partials/nav') %>

  <!-- Hero -->
  <section class="cs-hero">
    <div class="cs-hero-bg"></div>
    <div class="cs-hero-overlay"></div>
    <div class="cs-hero-content">
      <span class="cs-hero-eyebrow">Case Study</span>
      <h1 class="cs-hero-title">Building Brand<br>Advocacy</h1>
      <p class="cs-hero-sub">Podcast Production — Archive House Agency</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="cs-stats">
    <div class="cs-stats-inner">
      <div class="cs-stat reveal">
        <span class="cs-stat-num">20K+</span>
        <span class="cs-stat-label">YouTube Views</span>
      </div>
      <div class="cs-stat reveal reveal-delay-1">
        <span class="cs-stat-num">30</span>
        <span class="cs-stat-label">Assets</span>
      </div>
      <div class="cs-stat reveal reveal-delay-2">
        <span class="cs-stat-num">3</span>
        <span class="cs-stat-label">Episodes</span>
      </div>
      <div class="cs-stat reveal">
        <span class="cs-stat-num">27</span>
        <span class="cs-stat-label">Short Form Clips</span>
      </div>
    </div>
  </section>

  <!-- Artist Links -->
  <div class="cs-artist-links reveal">
    <span class="cs-artist-label">Follow BBA</span>
    <a href="https://www.youtube.com/@buildingbrandadvocacy" target="_blank" class="cs-artist-link" aria-label="YouTube">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
    </a>
    <a href="https://linktr.ee/building_brand_advocacy" target="_blank" class="cs-artist-link" aria-label="Linktree">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M7.953 15.066l-.038-4.017-3.97-.005.058-2.068 3.97.005.02-2.958-1.39-1.863L8.56 2.19l3.45 4.616 3.457-4.616 1.954 1.97-1.386 1.863.02 2.958 3.968-.005.058 2.068-3.97.005-.038 4.017h-2.2l-.038-4.017h-3.682l-.038 4.017H7.953zM10.12 19.78h3.76V24h-3.76v-4.22z"/></svg>
    </a>
  </div>

  <!-- Media -->
  <section class="cs-media">
    <div class="cs-media-grid">
      <div class="cs-media-item reveal">
        <iframe src="https://www.youtube.com/embed/_ZdEx2-OBzo" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
      <div class="cs-media-item reveal reveal-delay-1">
        <iframe src="https://www.youtube.com/embed/UIb2_jihGjI" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
      <div class="cs-media-item reveal reveal-delay-2">
        <iframe src="https://www.youtube.com/embed/ZB9H2mvSUys" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <!-- About the Production -->
  <section class="cs-content">
    <div class="cs-content-inner reveal">
      <div class="cs-content-left">
        <span class="cs-content-eyebrow">The Production</span>
        <h2 class="cs-content-heading">How We<br>Built It</h2>
      </div>
      <div class="cs-content-right">
        <p>Braxton Studios partnered with Archive House Agency to produce the Building Brand Advocacy podcast from the ground up. Our team handled the full end-to-end production pipeline — from pre-production planning and set design through to filming, editing, and final delivery.</p>
        <p>Every episode was crafted with a cinematic approach, bringing a premium visual standard to the podcast format. We managed multi-camera setups, lighting design, audio engineering, and post-production to ensure each episode felt polished and on-brand.</p>
        <p>The result was a series that not only resonated with the target audience but drove meaningful engagement, establishing Building Brand Advocacy as a standout voice in the brand marketing space.</p>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <%- include('partials/scripts') %>
</body>
</html>
